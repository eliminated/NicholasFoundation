# ─── SMTP Configuration (for local dev email sending) ───────────────────────
# Gmail example: Use an App Password (not your main password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# ─── Contact Form ────────────────────────────────────────────────────────────
# Where contact form submissions get sent
CONTACT_TO=hello@nicholasfoundation.org
# Who the "from" name shows as in the inbox
CONTACT_FROM_NAME=TNF Website

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── EmailJS (production newsletter — fill in from emailjs.com dashboard) ───
# Used in enhancements.js on the client side (safe to expose in JS)
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx
